{
  "name": "openpanelspa",
  "version": "0.0.1",
  "author": "Openpanel Team",
  "config": {
    "coreui_library_short_version": "4.5",
    "coreui_library_docs_url": "https://coreui.io/angular/docs/"
  },
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:mem": "set NODE_OPTIONS=--max-old-space-size=4096 && ng serve",
    "build": "ng build",
    "build:mem": "set NODE_OPTIONS=--max-old-space-size=4096 && ng build",
    "watch": "ng build --watch --configuration development",
    "format": "prettier --write . --ignore-path .gitignore",
    "format:check": "prettier --check . --ignore-path .gitignore",
    "test": "ng test",
    "test:firefox": "ng test --watch=false --browsers=Firefox",
    "test:ci": "ng test --watch=false --browsers=ChromeHeadlessNoSandbox",
    "test:coverage": "ng test --watch=false --code-coverage --browsers=ChromeHeadlessNoSandbox",
    "e2e": "playwright test"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.0.6",
    "@angular/cdk": "^21.0.3",
    "@angular/common": "^21.0.6",
    "@angular/compiler": "^21.0.6",
    "@angular/core": "^21.0.6",
    "@angular/forms": "^21.0.6",
    "@angular/platform-browser": "^21.0.6",
    "@angular/platform-browser-dynamic": "^21.0.6",
    "@angular/router": "^21.0.6",
    "@ckeditor/ckeditor5-angular": "^11.0.0",
    "@ckeditor/ckeditor5-build-classic": "^44.3.0",
    "@ckeditor/ckeditor5-ckbox": "^47.3.0",
    "@ckeditor/ckeditor5-utils": "^47.3.0",
    "@ckeditor/ckeditor5-watchdog": "^47.3.0",
    "@coreui/angular": "^5.6.2",
    "@coreui/angular-chartjs": "^5.6.2",
    "@coreui/chartjs": "^4.1.0",
    "@coreui/coreui": "^5.4.3",
    "@coreui/icons": "^3.0.1",
    "@coreui/icons-angular": "^5.6.2",
    "bootstrap": "^5.3.8",
    "chart.js": "^4.5.1",
    "file-saver": "^2.0.5",
    "jszip": "^3.10.1",
    "ngx-scrollbar": "^19.0.0",
    "rxjs": "~7.8.1",
    "serve": "^14.0.1",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular/build": "^21.0.3",
    "@angular/cli": "^21.0.3",
    "@angular/compiler-cli": "^21.0.6",
    "@angular/language-service": "^21.0.6",
    "@angular/localize": "^21.0.6",
    "@playwright/test": "^1.57.0",
    "playwright": "^1.57.0",
    "@types/file-saver": "^2.0.7",
    "@types/jasmine": "^5.1.4",
    "@types/node": "^18.18.13",
    "jasmine-core": "~5.1.1",
    "karma": "~6.4.2",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.1",
    "karma-firefox-launcher": "^2.1.3",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "prettier": "^3.6.2",
    "sass": "^1.69.0",
    "typescript": "~5.9.3"
  },
  "prettier": {
    "tabWidth": 2,
    "useTabs": false,
    "singleQuote": true,
    "endOfLine": "auto"
  },
  "engines": {
    "node": ">=20.19.0",
    "npm": ">=10.0.0"
  },
  "overrides": {
    "node-forge": "^1.3.2",
    "mdast-util-to-hast": "13.2.1",
    "tmp": "^0.2.4"
  },
  "eslintIgnore": [
    "**/node_modules/**",
    "**/dist/**",
    "**/coverage/",
    "src/polyfills.ts"
  ]
}
