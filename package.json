{
  "name": "openpanelspa",
  "version": "0.0.1",
  "author": "Openpanel Team",
  "config": {
    "coreui_library_short_version": "4.5",
    "coreui_library_docs_url": "https://coreui.io/angular/docs/"
  },
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:mem": "set NODE_OPTIONS=--max-old-space-size=4096 && ng serve",
    "build": "ng build",
    "build:mem": "set NODE_OPTIONS=--max-old-space-size=4096 && ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:firefox": "ng test --watch=false --browsers=Firefox",
    "test:ci": "ng test --watch=false --browsers=ChromeHeadless",
    "test:coverage": "ng test --watch=false --code-coverage --browsers=ChromeHeadless",
    "e2e": "playwright test"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^16.2.12",
    "@angular/cdk": "^16.2.12",
    "@angular/common": "^16.2.12",
    "@angular/compiler": "^16.2.12",
    "@angular/core": "^16.2.12",
    "@angular/forms": "^16.2.12",
    "@angular/platform-browser": "^16.2.12",
    "@angular/platform-browser-dynamic": "^16.2.12",
    "@angular/router": "^16.2.12",
    "@ckeditor/ckeditor5-angular": "^9.1.0",
    "@ckeditor/ckeditor5-build-classic": "^44.3.0",
    "@ckeditor/ckeditor5-ckbox": "^44.3.0",
    "@ckeditor/ckeditor5-utils": "^44.3.0",
    "@ckeditor/ckeditor5-watchdog": "^44.3.0",
    "@coreui/angular": "~4.5.28",
    "@coreui/angular-chartjs": "~4.5.28",
    "@coreui/chartjs": "^3.1.2",
    "@coreui/coreui": "^4.2.6",
    "@coreui/icons": "^3.0.1",
    "@coreui/icons-angular": "~4.5.28",
    "bootstrap": "^5.2.0",
    "chart.js": "^3.9.1",
    "file-saver": "^2.0.5",
    "jszip": "^3.10.1",
    "ngx-scrollbar": "^13.0.3",
    "rxjs": "~7.8.1",
    "serve": "^14.0.1",
    "tslib": "^2.3.0",
    "zone.js": "~0.13.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^16.2.10",
    "@angular/cli": "^16.2.10",
    "@angular/compiler-cli": "^16.2.12",
    "@angular/localize": "^16.2.12",
    "@angular/language-service": "^16.2.12",
    "@playwright/test": "^1.57.0",
    "@types/file-saver": "^2.0.7",
    "@types/jasmine": "^5.1.4",
    "@types/node": "^18.18.13",
    "jasmine-core": "~5.1.1",
    "karma": "~6.4.2",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.1",
    "karma-firefox-launcher": "^2.1.3",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "puppeteer": "^24.31.0",
    "sass": "^1.69.0",
    "typescript": "~4.9.5"
  },
  "engines": {
    "node": ">=20.19.0",
    "npm": ">=10.0.0"
  },
  "overrides": {
    "node-forge": "^1.3.2",
    "mdast-util-to-hast": "13.2.1",
    "tmp": "^0.2.4"
  },
  "eslintIgnore": [
    "**/node_modules/**",
    "**/dist/**",
    "**/coverage/",
    "src/polyfills.ts"
  ]
}
