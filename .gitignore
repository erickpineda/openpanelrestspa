# Node artifact files
node_modules/
dist/
.angular/

# Angular specific
/. angular/cache
. sass-cache/
/connect.lock
/coverage
/libpeerconnection.log
npm-debug.log
yarn-error.log
testem.log
/typings

# System Files
.DS_Store
Thumbs.db

# IDEs
.idea/
. vscode/
*.swp
*.swo
*~
. project
.classpath
.c9/
*. launch
.settings/
*. sublime-workspace

# Compiled Java class files
*.class

# Compiled Python bytecode
*.py[cod]

# Log files
*. log

# Package files
*.jar

# Maven
target/

# Unit test reports
TEST*.xml
/reports

# Applications
*.app
*.exe
*. war

# Large media files
*. mp4
*.tiff
*. avi
*.flv
*. mov
*.wmv

# Optional: Si tienes documentación generada
/docs/generated
/compodoc

# Optional: Build temporales
*.ngfactory. ts
*.ngsummary.json
*. shim.ts