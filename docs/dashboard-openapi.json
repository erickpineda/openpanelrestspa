{
  "openapi": "3.0.0",
  "info": {
    "title": "Openpanel Dashboard API (lite)",
    "version": "1.0.0",
    "description": "Slim OpenAPI-like contract for SPA/AI integration for dashboard features"
  },
  "servers": [
    {
      "url": "http://localhost:8080"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "ActivityPointDTO": {
        "type": "object",
        "properties": {
          "date": {
            "type": "string",
            "format": "date",
            "example": "2025-10-22"
          },
          "entradas": {
            "type": "integer",
            "example": 2
          },
          "comentarios": {
            "type": "integer",
            "example": 5
          },
          "usuarios": {
            "type": "integer",
            "example": 1
          }
        }
      },
      "TopItemDTO": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "count": {
            "type": "integer"
          }
        }
      },
      "SummaryDTO": {
        "type": "object",
        "properties": {
          "totalUsuarios": {
            "type": "integer"
          },
          "totalEntradas": {
            "type": "integer"
          },
          "totalComentarios": {
            "type": "integer"
          },
          "totalFicheros": {
            "type": "integer"
          },
          "storageBytes": {
            "type": "integer"
          },
          "ultimasEntradas": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "integer"
                },
                "titulo": {
                  "type": "string"
                },
                "fechaCreacion": {
                  "type": "string"
                },
                "idUsuario": {
                  "type": "integer"
                },
                "estado": {
                  "type": "string"
                }
              }
            }
          },
          "ultimosComentarios": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "integer"
                },
                "contenidoCorto": {
                  "type": "string"
                },
                "fechaCreacion": {
                  "type": "string"
                },
                "idUsuario": {
                  "type": "integer"
                },
                "idEntrada": {
                  "type": "integer"
                }
              }
            }
          },
          "ultimosUsuarios": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "integer"
                },
                "username": {
                  "type": "string"
                },
                "email": {
                  "type": "string"
                },
                "fechaRegistro": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/api/v1/dashboard/summary": {
      "get": {
        "summary": "Panel resumen",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Summary",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SummaryDTO"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/dashboard/recent-activity": {
      "get": {
        "summary": "Actividades recientes paginadas",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            }
          },
          {
            "name": "size",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 5
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Paged recent activity (see summary for shapes)"
          }
        }
      }
    },
    "/api/v1/dashboard/series/activity": {
      "get": {
        "summary": "Serie diaria de actividad",
        "parameters": [
          {
            "name": "days",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 30
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Array de puntos de actividad",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ActivityPointDTO"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/dashboard/top": {
      "get": {
        "summary": "Top N (users|categories)",
        "parameters": [
          {
            "name": "type",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "users",
                "categories"
              ],
              "default": "users"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 10
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Array of TopItemDTO",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/TopItemDTO"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/dashboard/storage": {
      "get": {
        "summary": "Storage metrics",
        "responses": {
          "200": {
            "description": "storage object"
          }
        }
      }
    },
    "/api/v1/dashboard/content-stats": {
      "get": {
        "summary": "Content stats and distribution",
        "responses": {
          "200": {
            "description": "content stats object"
          }
        }
      }
    }
  }
}
