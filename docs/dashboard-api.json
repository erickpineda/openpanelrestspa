{
  "info": {
    "title": "Dashboard API - OpenAPI-lite contract",
    "version": "1.0.0",
    "description": "Contrato ligero para la SPA: endpoints, samples, DTOs, cache keys y ejemplos de consumo."
  },
  "basePath": "/api/v1/dashboard",
  "endpoints": [
    {
      "path": "/summary",
      "method": "GET",
      "authRequired": true,
      "permissions": ["VER_CONTENIDO_RESTRINGIDO"],
      "description": "Panel resumido con totales y últimos N items.",
      "params": [],
      "cache": {
        "key": "dashboard:summary",
        "ttlSecondsConfigKey": "dashboard.cache.ttl.seconds",
        "ttlSecondsDefault": 60,
        "invalidations": ["evictSummary"]
      },
      "responseSample": {
        "success": true,
        "data": {
          "totalUsuarios": 1234,
          "totalEntradas": 4567,
          "totalComentarios": 7890,
          "totalFicheros": 321,
          "storageBytes": 987654321,
          "ultimasEntradas": [
            { "id": 101, "titulo": "Post ejemplo", "fechaCreacion": "2025-11-18T10:22:00Z", "idUsuario": 12, "estado": "PUBLICADA" }
          ],
          "ultimosComentarios": [
            { "id": 501, "contenidoCorto": "Gran artículo", "fechaCreacion": "2025-11-19T12:01:00Z", "idUsuario": 34, "idEntrada": 101 }
          ],
          "ultimosUsuarios": [
            { "id": 12, "username": "juan", "email": "juan@example.com", "fechaRegistro": "2025-10-01T08:00:00Z" }
          ]
        }
      }
    },
    {
      "path": "/recent-activity",
      "method": "GET",
      "authRequired": true,
      "description": "Lista paginada de actividad reciente (entradas, comentarios, usuarios).",
      "params": [
        { "name": "page", "in": "query", "required": false, "type": "integer", "default": 0 },
        { "name": "size", "in": "query", "required": false, "type": "integer", "default": 5 }
      ],
      "cache": { "enabled": false },
      "responseSample": {
        "success": true,
        "data": {
          "ultimasEntradas": [
            { "id": 101, "titulo": "Post ejemplo", "fechaCreacion": "2025-11-18T10:22:00Z", "idUsuario": 12, "estado": "PUBLICADA" }
          ],
          "ultimosComentarios": [
            { "id": 501, "contenidoCorto": "Gran artículo", "fechaCreacion": "2025-11-19T12:01:00Z", "idUsuario": 34, "idEntrada": 101 }
          ],
          "ultimosUsuarios": [
            { "id": 12, "username": "juan", "email": "juan@example.com", "fechaRegistro": "2025-10-01T08:00:00Z" }
          ],
          "page": 0,
          "size": 5,
          "totalPages": 10,
          "totalElements": 50
        }
      }
    },
    {
      "path": "/series/activity",
      "method": "GET",
      "authRequired": true,
      "description": "Serie temporal diaria de actividad (entradas, comentarios, usuarios) para N días.",
      "params": [
        { "name": "days", "in": "query", "required": false, "type": "integer", "default": 30 }
      ],
      "cache": {
        "keyPattern": "dashboard:series:activity:days:{N}",
        "ttlSecondsConfigKey": "dashboard.cache.ttl.seconds",
        "ttlSecondsDefault": 300,
        "invalidations": ["evictSeriesAll"]
      },
      "responseSample": {
        "success": true,
        "data": [
          { "date": "2025-10-22", "entradas": 2, "comentarios": 5, "usuarios": 1 },
          { "date": "2025-10-23", "entradas": 3, "comentarios": 1, "usuarios": 0 }
        ]
      }
    },
    {
      "path": "/top",
      "method": "GET",
      "authRequired": true,
      "description": "Top-N por tipo (users|categories).",
      "params": [
        { "name": "type", "in": "query", "required": true, "type": "string", "enum": ["users", "categories"] },
        { "name": "limit", "in": "query", "required": false, "type": "integer", "default": 10 }
      ],
      "cache": {
        "keyPattern": "dashboard:top:type:{type}:limit:{N}",
        "ttlSecondsConfigKey": "dashboard.cache.ttl.seconds",
        "ttlSecondsDefault": 600,
        "invalidations": ["evictTopAll", "evictTop(type)"]
      },
      "responseSample": {
        "success": true,
        "data": [
          { "name": "alice", "count": 120 },
          { "name": "bob", "count": 98 }
        ]
      }
    },
    {
      "path": "/storage",
      "method": "GET",
      "authRequired": true,
      "description": "Métrica de almacenamiento: número de ficheros y bytes usados.",
      "params": [],
      "cache": { "enabled": false },
      "responseSample": {
        "success": true,
        "data": { "totalFiles": 321, "storageBytes": 987654321 }
      }
    },
    {
      "path": "/content-stats",
      "method": "GET",
      "authRequired": true,
      "description": "Resumen detallado de contenido (totales y distribuciones).",
      "params": [],
      "cache": {
        "key": "dashboard:content-stats",
        "ttlSecondsConfigKey": "dashboard.cache.ttl.seconds",
        "ttlSecondsDefault": 300
      },
      "responseSample": {
        "success": true,
        "data": {
          "totalUsuarios": 1234,
          "totalEntradas": 4567,
          "totalComentarios": 7890,
          "totalFicheros": 321,
          "storageBytes": 987654321,
          "entradasByEstado": { "PUBLICADA": 23, "PENDIENTE_REVISION": 5 }
        }
      }
    }
  ],
  "dtos": {
    "ActivityPointDTO": {
      "date": "string (YYYY-MM-DD)",
      "entradas": "number",
      "comentarios": "number",
      "usuarios": "number"
    },
    "TopItemDTO": {
      "name": "string",
      "count": "number"
    },
    "SummaryDTO": {
      "totalUsuarios": "number",
      "totalEntradas": "number",
      "totalComentarios": "number",
      "totalFicheros": "number",
      "storageBytes": "number",
      "ultimasEntradas": "array of {id, titulo, fechaCreacion, idUsuario, estado}",
      "ultimosComentarios": "array of {id, contenidoCorto, fechaCreacion, idUsuario, idEntrada}",
      "ultimosUsuarios": "array of {id, username, email, fechaRegistro}"
    }
  },
  "errors": {
    "generalError": { "success": false, "message": "string", "errors": "array" },
    "auth": "401 or 403 depending on policy"
  },
  "examples": {
    "fetch": {
      "fetchSummary": "async function fetchSummary(token) { const res = await fetch('/api/v1/dashboard/summary', { headers: { 'Authorization': 'Bearer ' + token, 'Accept': 'application/json' } }); const body = await res.json(); return body.data; }",
      "fetchSeries": "async function fetchActivitySeries(days = 30, token) { const res = await fetch(`/api/v1/dashboard/series/activity?days=${days}`, { headers: { 'Authorization': 'Bearer ' + token } }); const body = await res.json(); return body.data; }"
    },
    "axios": {
      "axiosSummary": "async function axiosSummary(token) { const res = await axios.get('/api/v1/dashboard/summary', { headers: { Authorization: 'Bearer ' + token } }); return res.data.data; }",
      "axiosSeries": "async function axiosSeries(days = 30, token) { const res = await axios.get('/api/v1/dashboard/series/activity', { params: { days }, headers: { Authorization: 'Bearer ' + token } }); return res.data.data; }"
    }
  },
  "uiMapping": {
    "metricCards": {
      "source": "/summary",
      "cards": [
        { "label": "Usuarios", "field": "totalUsuarios", "format": "number" },
        { "label": "Entradas", "field": "totalEntradas", "format": "number" },
        { "label": "Comentarios", "field": "totalComentarios", "format": "number" },
        { "label": "Almacenamiento (MB)", "field": "storageBytes", "format": "bytesToMB" }
      ]
    },
    "mainChart": {
      "source": "/series/activity?days=30",
      "type": "line",
      "datasets": [
        { "label": "Entradas", "path": "entradas", "color": "#1f77b4" },
        { "label": "Comentarios", "path": "comentarios", "color": "#ff7f0e" },
        { "label": "Usuarios", "path": "usuarios", "color": "#2ca02c" }
      ],
      "labelsPath": "date"
    },
    "recentEntriesTable": {
      "source": "/summary",
      "path": "ultimasEntradas",
      "columns": ["id", "titulo", "idUsuario", "fechaCreacion", "estado"]
    },
    "topUsersBar": {
      "source": "/top?type=users&limit=10",
      "type": "bar",
      "labelsPath": "name",
      "valuesPath": "count"
    },
    "storageWidget": {
      "source": "/storage",
      "fields": ["totalFiles", "storageBytes"]
    },
    "contentStats": {
      "source": "/content-stats",
      "fields": ["entradasByEstado"]
    }
  },
  "updatePatterns": {
    "polling": {
      "summaryIntervalSeconds": 30,
      "seriesIntervalSeconds": 300
    },
    "realtime": {
      "recommended": "SSE/WebSocket for DASHBOARD_UPDATE messages. Use message payload or trigger a re-fetch for affected endpoints."
    },
    "invalidateOnChange": "After SPA does create/update/delete operations, call the backend invalidation (if available) or re-fetch affected endpoints (summary, series, top)."
  },
  "operationalNotes": {
    "ETagSupport": "If backend exposes ETag/If-None-Match use it to reduce bandwidth.",
    "cacheRules": "Short TTLs for summary (default 60s). Series/top can have longer TTLs if activity is low.",
    "security": "All endpoints require Authorization header. Prefer Bearer tokens and validate permissions on server side."
  }
}
