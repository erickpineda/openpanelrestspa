{
  "openapi": "3.0.0",
  "info": {
    "title": "Openpanel Dashboard API (lite)",
    "version": "1.0.0",
    "description": "Slim OpenAPI-like contract for SPA/AI integration for dashboard features"
  },
  "servers": [
    {
      "url": "http://localhost:8080"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "ActivityPointDTO": {
        "type": "object",
        "properties": {
          "date": {
            "type": "string",
            "format": "date",
            "example": "2025-10-22"
          },
          "entradas": {
            "type": "integer",
            "example": 2
          },
          "comentarios": {
            "type": "integer",
            "example": 5
          },
          "usuarios": {
            "type": "integer",
            "example": 1
          }
        }
      },
      "TopItemDTO": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "count": {
            "type": "integer"
          }
        }
      },
      "SummaryDTO": {
        "type": "object",
        "properties": {
          "totalUsuarios": { "type": "integer" },
          "totalEntradas": { "type": "integer" },
          "totalComentarios": { "type": "integer" },
          "totalFicheros": { "type": "integer" },
          "storageBytes": { "type": "integer" },
          "ultimasEntradas": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": { "type": "integer" },
                "titulo": { "type": "string" },
                "fechaCreacion": { "type": "string" },
                "idUsuario": { "type": "integer" },
                "estado": { "type": "string" }
              }
            }
          },
          "ultimosComentarios": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": { "type": "integer" },
                "contenidoCorto": { "type": "string" },
                "fechaCreacion": { "type": "string" },
                "idUsuario": { "type": "integer" },
                "idEntrada": { "type": "integer" }
              }
            }
          },
          "ultimosUsuarios": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": { "type": "integer" },
                "username": { "type": "string" },
                "email": { "type": "string" },
                "fechaRegistro": { "type": "string" }
              }
            }
          },
          "entradasByEstado": {
            "type": "object",
            "additionalProperties": { "type": "integer" },
            "description": "Mapa de estados posibles de la entrada y su cantidad. Ejemplo: { 'PUBLICADA': 7000, 'NO PUBLICADA': 0, ... }. Los estados posibles se obtienen de EstadoEntradaEnum."
          }
        }
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/api/v1/dashboard/summary": {
      "get": {
        "summary": "Panel resumen",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Summary",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SummaryDTO"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/dashboard/recent-activity": {
      "get": {
        "summary": "Actividades recientes paginadas",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            }
          },
          {
            "name": "size",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 5
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Paged recent activity (see summary for shapes)"
          }
        }
      }
    },
    "/api/v1/dashboard/series/activity": {
      "get": {
        "summary": "Serie diaria de actividad (o por hora)",
        "parameters": [
          {
            "name": "days",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 30
            },
            "description": "Días a mostrar. Si granularity=hour, 'days' se interpreta como horas. Normalizado: <=0 -> 30; max 365"
          },
          {
            "name": "granularity",
            "in": "query",
            "schema": { "type": "string", "enum": ["hour","day","week","month"], "default": "day" },
            "description": "Granularidad de la serie: 'hour'|'day'|'week'|'month'"
          }
        ],
        "responses": {
          "200": {
            "description": "Array de puntos de actividad (ActivityPointDTO o ActivityHourPointDTO si granularity=hour)",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ActivityPointDTO"
                  }
                },
                "example": {
                  "result": { "timestamp": "2025-11-24 00:00:00", "trackingId": "abc-200", "success": true, "message": "OK" },
                  "data": { "$ref": "../examples/series-hour.json" }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/dashboard/top": {
      "get": {
        "summary": "Top N (users|categories)",
        "parameters": [
          {
            "name": "type",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "users",
                "categories"
              ],
              "default": "users"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 10
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Array of TopItemDTO",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/TopItemDTO"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/dashboard/storage": {
      "get": {
        "summary": "Storage metrics",
        "responses": {
          "200": {
            "description": "storage object"
          }
        }
      }
    },
    "/api/v1/dashboard/content-stats": {
      "get": {
        "summary": "Content stats and distribution",
      "responses": {
          "200": {
            "description": "content stats object"
          }
        }
      }
    },
    "/api/v1/dashboard/series/entries": {
      "get": {
        "summary": "Series de entradas (split por estado, agrupado por fecha)",
        "parameters": [
          { "name": "days", "in": "query", "schema": { "type": "integer", "default": 30 }, "description": "Días a mostrar. Normalizado: <=0 -> 30; max 365" },
          { "name": "split", "in": "query", "schema": { "type": "string", "default": "estado", "enum": ["estado","estadoNombre"] }, "description": "Parámetro legacy/alternativo: estado o estadoNombre; si no soportado devuelve 400" },
          { "name": "granularity", "in": "query", "schema": { "type": "string", "default": "day", "enum": ["hour","day","week","month"] } }
        ],
        "responses": {
          "200": {
            "description": "Array de puntos split por estado agrupado por fecha",
            "content": {
              "application/json": {
                "example": [
                  { "date": "2025-11-24", "entradasByEstado": { "PUBLICADA": 10, "NO PUBLICADA": 2, "GUARDADA": 0, "PENDIENTE_REVISION": 1, "EN_REVISION": 0, "REVISADA": 0, "PROGRAMADA": 0, "HISTORICA": 0 } },
                  { "date": "2025-11-25", "entradasByEstado": { "PUBLICADA": 8, "NO PUBLICADA": 1, "GUARDADA": 0, "PENDIENTE_REVISION": 0, "EN_REVISION": 0, "REVISADA": 0, "PROGRAMADA": 0, "HISTORICA": 0 } }
                ]
              }
            }
          },
          "400": { "description": "Parámetro split no soportado" }
        }
      }
    }
  }
}